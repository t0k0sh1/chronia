{
  "name": "chronia",
  "version": "1.0.3",
  "type": "module",
  "description": "A modern, lightweight TypeScript date/time utility library with comprehensive formatting, parsing, and manipulation capabilities.",
  "license": "MIT",
  "author": "Takashi Yamashina <takashi.yamashina@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t0k0sh1/chronia.git"
  },
  "homepage": "https://t0k0sh1.github.io/chronia/",
  "bugs": {
    "url": "https://github.com/t0k0sh1/chronia/issues"
  },
  "keywords": [
    "chronia",
    "date",
    "time",
    "datetime",
    "utility",
    "utils",
    "typescript",
    "javascript"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "RELEASE.md",
    "LICENSE"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js",
      "require": "./dist/i18n/index.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint ./src && prettier --check 'docs/**/*.md' 'README.md'",
    "lint:fix": "eslint ./src --fix && prettier --write 'docs/**/*.md' 'README.md'"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.0",
    "prettier": "^3.7.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "overrides": {
      "yaml": "^2.8.3"
    }
  }
}
